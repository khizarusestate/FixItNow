# API Configuration
# Development: http://localhost:5000/api
# Production: https://your-domain.com/api
# Use /api in dev so Vite proxies API, uploads, and Socket.IO (backend on :5000)
VITE_API_BASE_URL=/api

# HttpOnly cookie auth (default true — tokens not stored in localStorage)
# VITE_USE_HTTPONLY_COOKIES=true
# Or direct: VITE_API_BASE_URL=http://localhost:5000/api

# Optional: Socket.IO when API and app are on different hosts
# VITE_SOCKET_URL=https://api.yourdomain.com

# Location picker uses OpenStreetMap + Leaflet (geocoding via backend /api/geocode).
# No Google Maps API key required.

# Google Sign-In (customer login/signup) — Web client ID from Google Cloud Console
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Payment instructions shown on booking form (JazzCash)
# VITE_PLATFORM_JAZZCASH_MSISDN=03XXXXXXXXX
# VITE_PLATFORM_WALLET_MSISDN=03XXXXXXXXX
